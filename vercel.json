{
  "version": 2,
  "functions": {
    "api/gateway.js": {
      "memory": 128,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/my-sync(.*)",
      "destination": "/api/gateway"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "trailingSlash": false
}
