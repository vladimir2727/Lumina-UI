{
  "version": 2,
  "functions": {
    "api/gateway.js": {
      "memory": 128,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/gateway"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
